<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">



    <changeSet id="create-organization-table" author="Ibrahim.AlBahra">
        <createTable tableName="organization">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="organization_pkey"/>
            </column>
            <column name="organization_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="organization_email" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="insert-default-organization" author="Ibrahim.AlBahra">
        <preConditions onFail="MARK_RAN">
            <rowCount expectedRows="0" tableName="organization"/>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM organization WHERE organization_name = 'Default Organization'
            </sqlCheck>
            <not>
                <rowCount expectedRows="0" tableName="project"/>
            </not>
            <not>
                <rowCount expectedRows="0" tableName="software_component"/>
            </not>
            <not>
                <rowCount expectedRows="0" tableName="vulnerability"/>
            </not>
            <not>
                <rowCount expectedRows="0" tableName="inventory_item"/>
            </not>
            <not>
                <rowCount expectedRows="0" tableName="license"/>
            </not>
            <not>
                <rowCount expectedRows="0" tableName="copyright"/>
            </not>
        </preConditions>
        <insert tableName="organization">
            <column name="id" valueComputed="next('seq_id_organization')"/>
            <column name="organization_name" value="Default Organization"/>
        </insert>
    </changeSet>


    <changeSet id="add-organization-id-to-project" author="Ibrahim.AlBahra">
        <addColumn tableName="project">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-organization-id-to-software-component" author="Ibrahim.AlBahra">
        <addColumn tableName="software_component">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-organization-id-to-vulnerability" author="Ibrahim.AlBahra">
        <addColumn tableName="vulnerability">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-organization-id-to-inventory-item" author="Ibrahim.AlBahra">
        <addColumn tableName="inventory_item">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-organization-id-to-license" author="Ibrahim.AlBahra">
        <addColumn tableName="license">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-organization-id-to-copyright" author="Ibrahim.AlBahra">
        <addColumn tableName="copyright">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-organization-id-to-suggestion" author="Ibrahim.AlBahra">
        <addColumn tableName="suggestion">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-organization-id-to-user" author="Ibrahim.AlBahra">
        <addColumn tableName="user_">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>


    <changeSet id="populate-organization-id-existing-data" author="Ibrahim.AlBahra">

        <preConditions onFail="HALT">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM organization WHERE organization_name = 'Default Organization'
            </sqlCheck>
        </preConditions>

        <update tableName="project">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

        <update tableName="software_component">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

        <update tableName="vulnerability">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

        <update tableName="inventory_item">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

        <update tableName="license">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

        <update tableName="copyright">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

        <update tableName="suggestion">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

        <update tableName="user_">
            <column name="organization_id"
                    valueComputed="(SELECT id FROM organization WHERE organization_name = 'Default Organization')"/>
            <where>organization_id IS NULL</where>
        </update>

    </changeSet>

    <changeSet id="add-not-null-organization-id-project" author="Ibrahim.AlBahra">
        <addNotNullConstraint tableName="project"
                              columnName="organization_id"
                              columnDataType="BIGINT"/>
    </changeSet>

    <changeSet id="add-not-null-organization-id-software-component" author="Ibrahim.AlBahra">
        <addNotNullConstraint tableName="software_component"
                              columnName="organization_id"
                              columnDataType="BIGINT"/>
    </changeSet>

    <changeSet id="add-not-null-organization-id-vulnerability" author="Ibrahim.AlBahra">
        <addNotNullConstraint tableName="vulnerability"
                              columnName="organization_id"
                              columnDataType="BIGINT"/>
    </changeSet>


    <changeSet id="drop-organization-columns-from-project" author="Ibrahim.AlBahra">
        <dropColumn tableName="project" columnName="organization_name"/>
        <dropColumn tableName="project" columnName="organization_email"/>
    </changeSet>

    <changeSet id="add-unique-constraints-organization-name" author="">
        <addUniqueConstraint tableName="organization"
                             columnNames="organization_name"
                             constraintName="unq_organization_name"/>
    </changeSet>

    <changeSet id="add-unique-constraint-project-org-name-version" author="Ibrahim.AlBahra">
        <addUniqueConstraint tableName="project"
                             columnNames="organization_id, project_name, version"
