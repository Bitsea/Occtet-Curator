    <changeSet id="add-fk-project-organization-id" author="Ibrahim.AlBahra">
        <addForeignKeyConstraint baseTableName="project"
                                 baseColumnNames="organization_id"
                                 referencedTableName="organization"
                                 referencedColumnNames="id"
                                 constraintName="fk_project_organization_id"
                                 deferrable="false"
                                 initiallyDeferred="false"
                                 onDelete="NO ACTION"
                                 onUpdate="NO ACTION"/>
    </changeSet>

