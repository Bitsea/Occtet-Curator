<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="expand-license-and-url-types" author="Ibrahim.AlBahra">

        <modifyDataType tableName="license" columnName="license_name" newDataType="TEXT"/>
        <modifyDataType tableName="license" columnName="license_type" newDataType="TEXT"/>
        <modifyDataType tableName="ort_violation" columnName="license" newDataType="TEXT"/>
        <modifyDataType tableName="spdx_document_root" columnName="data_license" newDataType="TEXT"/>

        <modifyDataType tableName="license" columnName="details_url" newDataType="TEXT"/>
        <modifyDataType tableName="software_component" columnName="details_url" newDataType="TEXT"/>
        <modifyDataType tableName="software_component" columnName="purl" newDataType="TEXT"/>
        <modifyDataType tableName="spdx_package_entity" columnName="download_location" newDataType="TEXT"/>
        <modifyDataType tableName="external_ref_entity" columnName="reference_locator" newDataType="TEXT"/>
        <modifyDataType tableName="ort_issue" columnName="purl" newDataType="TEXT"/>
        <modifyDataType tableName="ort_violation" columnName="purl" newDataType="TEXT"/>
        <modifyDataType tableName="spdx_document_root" columnName="document_uri" newDataType="TEXT"/>
        <modifyDataType tableName="vulnerability" columnName="source_url" newDataType="TEXT"/>

        <modifyDataType tableName="software_component" columnName="software_component_name" newDataType="TEXT"/>
        <modifyDataType tableName="organization" columnName="organization_name" newDataType="TEXT"/>
        <modifyDataType tableName="organization" columnName="organization_email" newDataType="TEXT"/>
        <modifyDataType tableName="spdx_package_entity" columnName="name" newDataType="TEXT"/>
        <modifyDataType tableName="spdx_document_root" columnName="name" newDataType="TEXT"/>
        <modifyDataType tableName="creation_info_entity" columnName="creators" newDataType="TEXT"/>
        <modifyDataType tableName="USER_" columnName="EMAIL" newDataType="TEXT"/>

        <modifyDataType tableName="configuration" columnName="value" newDataType="TEXT"/>
        <modifyDataType tableName="dblog" columnName="component" newDataType="TEXT"/>

    </changeSet>

</databaseChangeLog>