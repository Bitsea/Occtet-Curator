    <changeSet id="3-fill-missing-project-contact" author="Ibrahim.AlBahra">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="PROJECT"/>
            <columnExists tableName="PROJECT" columnName="PROJECT_CONTACT"/>
        </preConditions>

        <update tableName="PROJECT">
            <column name="PROJECT_CONTACT" value="UNKNOWN"/>
            <where>PROJECT_CONTACT IS NULL</where>
        </update>
    </changeSet>


    <changeSet id="4-fill-organization-name" author="Ibrahim.AlBahra">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="PROJECT"/>
            <columnExists tableName="PROJECT" columnName="ORGANIZATION_NAME"/>
        </preConditions>

        <update tableName="PROJECT">
            <column name="ORGANIZATION_NAME" value="UNKNOWN"/>
            <where>ORGANIZATION_NAME IS NULL</where>
        </update>
    </changeSet>
</databaseChangeLog>