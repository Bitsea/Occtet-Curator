<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">


    <changeSet id="migrate-usage-licenses-link-table-1" author="leoni">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="SOFTWARE_COMPONENT_LICENSE_LINK"/>
        </preConditions>
        <renameTable oldTableName="SOFTWARE_COMPONENT_LICENSE_LINK" newTableName="SOFTWARE_COMPONENT_LICENSE_USAGE"/>

        <dropPrimaryKey tableName="SOFTWARE_COMPONENT_LICENSE_USAGE" />

        <addColumn tableName="SOFTWARE_COMPONENT_LICENSE_USAGE">
            <column name="ID" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_SOFTWARE_COMPONENT_LICENSE_USAGE"/>
            </column>
            <column name="CUSTOM_TEXT" type="CLOB"/>
            <column name="MODIFIED" type="BOOLEAN"/>
            <column name="CURATED" type="BOOLEAN"/>
            <column name="CUSTOM_NAME" type="text"/>
            <column name="ORGANIZATION_ID" type="BIGINT"/>
        </addColumn>

    </changeSet>
    <changeSet id="license-entity" author="leoni">

        <dropColumn tableName="SOFTWARE_COMPONENT_LICENSE_USAGE" columnName="CUSTOM_LICENSE_ID"/>

    </changeSet>

    <changeSet id="license-entity-adjusting" author="leoni">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="LICENSE" columnName="LICENSE_TEXT"/>
        </preConditions>

        <renameColumn tableName="LICENSE" oldColumnName="LICENSE_TEXT" newColumnName="TEMPLATE_TEXT"/>
        <dropColumn tableName="LICENSE" columnName="CURATED"/>
        <dropColumn tableName="LICENSE" columnName="MODIFIED"/>
    </changeSet>

    <changeSet id="create-link-tables-for-usages" author="leoni">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="COPYRIGHT_LICENSE_USAGE_LINK"/>
            </not>
        </preConditions>
        <createTable tableName="COPYRIGHT_LICENSE_USAGE_LINK">
            <column name="COPYRIGHT_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="SOFTWARE_COMPONENT_LICENSE_USAGE_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Constraints für Copyright Link -->
        <addPrimaryKey tableName="COPYRIGHT_LICENSE_USAGE_LINK" columnNames="COPYRIGHT_ID, SOFTWARE_COMPONENT_LICENSE_USAGE_ID"/>

        <addForeignKeyConstraint baseTableName="COPYRIGHT_LICENSE_USAGE_LINK" baseColumnNames="COPYRIGHT_ID"
                                 referencedTableName="COPYRIGHT" referencedColumnNames="ID"
                                 constraintName="FK_COPY_LIC_USE_ON_COPYRIGHT"/>
        <addForeignKeyConstraint baseTableName="COPYRIGHT_LICENSE_USAGE_LINK" baseColumnNames="SOFTWARE_COMPONENT_LICENSE_USAGE_ID"
                                 referencedTableName="SOFTWARE_COMPONENT_LICENSE_USAGE" referencedColumnNames="ID"
                                 constraintName="FK_COPY_LIC_USE_ON_USAGE"/>


    </changeSet>


</databaseChangeLog>