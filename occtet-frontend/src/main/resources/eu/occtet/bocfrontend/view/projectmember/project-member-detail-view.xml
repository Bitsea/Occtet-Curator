<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://ProjectMember">
    <data>
        <instance id="projectMemberDc"
                  class="eu.occtet.bocfrontend.entity.ProjectMember">
            <fetchPlan extends="_base">
                <property name="project" fetchPlan="_base"/>
                <property name="user" fetchPlan="_base">
                    <property name="lastName"/>
                </property>
            </fetchPlan>
            <loader/>
        </instance>
    </data>

    <layout>

        <formLayout dataContainer="projectMemberDc">

            <entityPicker property="project" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.project"/>

            <textField property="user.lastName" label="msg://eu.occtet.bocfrontend.view.login/loginForm.username"/>

        </formLayout>

    </layout>

</view>