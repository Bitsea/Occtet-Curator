<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://eu.occtet.bocfrontend.view.ortViolation/caption"
      focusComponent="form">
    <data>
        <instance id="ortViolationDc"
                  class="eu.occtet.bocfrontend.entity.OrtViolation">

            <loader id="ortViolationDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>

        <vbox alignItems="CENTER" justifyContent="START" alignSelf="START" height="100%" width="100%">
            <formLayout id="form" dataContainer="ortViolationDc" width="100%" alignSelf="CENTER">
                <vbox width="100%">
                    <hbox>
                        <textField id="projectField" property="project.projectName" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.project" required="true"/>
                        <textField id="rule" property="rule" label="msg://rule" />
                    </hbox>
                    <hbox>
                        <textField id="purl" property="purl" label="msg://eu.occtet.bocfrontend.entity/SoftwareComponent.purl" />
                        <textField id="severity" property="severity" label="msg://eu.occtet.bocfrontend.entity/Vulnerability.weightedSeverity"/>
                    </hbox>
                    <hbox>
                        <textField id="howToFix" property="howToFix" label="msg://howToFix" />

                        <checkbox id="resolved" property="resolved" label="msg://eu.occtet.bocfrontend.view.ortViolation/resolved" alignSelf="END"/>

                    </hbox>
                    <hbox width="100%">
                        <textField id="license" property="license" label="msg://eu.occtet.bocfrontend.view/inventoryTabFragment.tabSheet.softwareComponent.license" />
                        <textField id="licenseSource" property="licenseSource" label="msg://licenseSource" />

                    </hbox>
                    <hbox width="100%">
                        <textField id="message" property="message" label="msg://eu.occtet.bocfrontend.view.ortViolation/message" width="100%"/>

                    </hbox>


                </vbox>
            </formLayout>
            <hbox id="detailActions" justifyContent="CENTER" alignItems="CENTER" alignSelf="CENTER" height="100%">
                <button id="saveAndCloseButton" action="saveAction" alignSelf="END"/>
                <button id="closeButton" action="closeAction" alignSelf="END"/>
            </hbox>
        </vbox>

    </layout>
</view>
