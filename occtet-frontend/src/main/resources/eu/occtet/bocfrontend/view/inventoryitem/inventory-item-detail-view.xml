<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://inventoryItemDetailView.title"
      focusComponent="form">
    <data>
        <instance id="inventoryItemDc"
                  class="eu.occtet.bocfrontend.entity.InventoryItem">
            <fetchPlan extends="_base">
                <property name="softwareComponent" fetchPlan="_base"/>
                <property name="parent" fetchPlan="_base">
                    <property name="inventoryName"/>
                </property>
            </fetchPlan>
            <loader id="inventoryItemDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <tabSheet width="100%" themeNames="no-padding" height="100%">
            <tab id="generalInformationTab" label="msg://eu.occtet.bocfrontend.view.inventoryitem/inventoryList.tab.general.label" >
                <vbox alignItems="CENTER" justifyContent="START" alignSelf="START" height="100%">
                    <formLayout id="form" dataContainer="inventoryItemDc" width="100%" alignSelf="CENTER">
                        <vbox id="inventoryNameField" width="100%"/>
                        <hbox>
                            <comboBox id="projectField" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.project" required="true"/>
                            <textField id="sizeField" property="size" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.size" width="10%"/>
                            <textField id="linkingField" property="linking" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.linking" width="10%"/>
                            <hbox>
                                <checkbox id="curatedField" property="curated" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.curated" alignSelf="END"/>
                                <checkbox id="wasCombinedField" property="wasCombined" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.wasCombined" alignSelf="END"/>
                            </hbox>
                        </hbox>
                        <hbox width="100%">
                            <comboBox id="parentField" property="parent"
                                       label="msg://eu.occtet.bocfrontend.entity/InventoryItem.parent" width="25em" css="margin-left: 30px"/>
                            <button id="parentButton" text="msg://showParent"
                                    width="15em" alignSelf="END"/>
                        </hbox>
                        <hbox width="100%">
                            <comboBox id="softwareComponentField" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.softwareComponent" width="25em"
                                      required="false"/>
                            <button id="softwareComponentButton" text="msg://eu.occtet.bocfrontend.view.inventoryitem/button.showComponent" width="15em" alignSelf="END"/>
                        </hbox>
                        <vbox id="auditNotesText" width="100%" height="100%"/>
                    </formLayout>
                    <hbox id="detailActions" justifyContent="CENTER" alignItems="CENTER" alignSelf="CENTER" height="100%">
                        <button id="saveAndCloseButton" action="saveAction" alignSelf="END"/>
                        <button id="closeButton" action="closeAction" alignSelf="END"/>
                    </hbox>
                </vbox>
            </tab>
        </tabSheet>
    </layout>
</view>
