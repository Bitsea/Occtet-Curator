<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:charts="http://jmix.io/schema/charts/ui"
      title="msg://dashboardView.title">
    <data>
        <collection id="projectsDc" class="eu.occtet.bocfrontend.entity.Project">
            <fetchPlan extends="_base"/>
            <loader id="projectsDl">
                <query>
                    <![CDATA[select e from Project e]]>
                </query>
            </loader>
        </collection>
        <collection id="vulnerabilitiesDc" class="eu.occtet.bocfrontend.entity.Vulnerability">
            <fetchPlan extends="_base"/>
            <loader id="vulnerabilitiesDl">
                <query>
                    <![CDATA[select v from Vulnerability v where v in :vulnerabilitiesProject]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <timer id="refreshTimer" delay="1000" autostart="true" repeating="true"/>
    </facets>
    <layout>
        <vbox width="100%" height="100%" expand="vulnerabilitiesGrid">
            <hbox width="45%" alignItems="STRETCH" classNames="box-layout" css="background-color:var(--lumo-contrast-5pct)">
                <vbox alignSelf="END">
                    <h5 text="msg://dashboardView.runningTasks"/>
                    <listBox id="runningTasksList" width="100%" height="100px" readOnly="true" css="background-color:var(--lumo-contrast-5pct)"/>
                </vbox>
            </hbox>
            <hbox width="100%" justifyContent="BETWEEN">
                <entityComboBox id="projectSelector"
                                label="msg://eu.occtet.bocfrontend.view.dashboard/dashboardView.projectSelector"
                                themeNames="small"
                                itemsContainer="projectsDc"
                                metaClass="Project"
                                width="20em"/>
                <simplePagination id="pagination" dataLoader="vulnerabilitiesDl" itemsPerPageItems="100"
                                  alignSelf="END"/>
            </hbox>
            <dataGrid id="vulnerabilitiesGrid"
                      dataContainer="vulnerabilitiesDc"
                      classNames="occtet-grid"
                      width="100%"
                      minHeight="30em">
                <columns>
                    <column property="vulnerabilityId" header="msg://eu.occtet.bocfrontend.entity/Vulnerability.vulnerabilityId" autoWidth="true" filterable="true"/>
                    <column property="riskScore" header="msg://eu.occtet.bocfrontend.entity/Vulnerability.riskScore" filterable="true"/>
                    <column property="severity" header="msg://eu.occtet.bocfrontend.entity/Vulnerability.weightedSeverity" filterable="true"/>
                </columns>
            </dataGrid>
            <hbox width="100%" height="40%"/>
            <hbox width="100%" minHeight="50%" alignItems="END">
                <charts:chart id="chartVulnerabilites" width="100%" height="100%" justifySelf="CENTER">
                    <charts:title text="msg://eu.occtet.bocfrontend.view.dashboard/dashboardView.charts.vulnerability.title"
                                  subtext="msg://eu.occtet.bocfrontend.view.dashboard/dashboardView.charts.vulnerability.subtext"/>
                    <charts:tooltip trigger="ITEM"/>
                    <charts:series>
                        <charts:pie radius="0% 65%">
                            <charts:label formatter="{b}: {d}%"/>
                        </charts:pie>
                    </charts:series>
                </charts:chart>
                <charts:chart id="chartSoftwareComponent" width="100%" height="100%" justifySelf="CENTER">
                    <charts:title text="msg://eu.occtet.bocfrontend.view.dashboard/dashboardView.charts.softwareComponent.title"
                                  subtext="msg://eu.occtet.bocfrontend.view.dashboard/dashboardView.charts.softwareComponent.subtext"/>
                    <charts:tooltip trigger="ITEM"/>
                    <charts:series>
                        <charts:pie radius="0% 65%">
                            <charts:label formatter="{b}: {d}%"/>
                        </charts:pie>
                    </charts:series>
                </charts:chart>
            </hbox>
        </vbox>
    </layout>
</view>