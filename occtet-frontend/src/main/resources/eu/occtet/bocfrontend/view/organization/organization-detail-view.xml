<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://organization"
      focusComponent="form">
    <data>
        <instance id="organizationDc"
                  class="eu.occtet.bocfrontend.entity.Organization">
            <loader id="organizationDl"/>

        </instance>
        <collection id="userDc"
                    class="eu.occtet.bocfrontend.entity.User">
            <fetchPlan extends="_base">
            </fetchPlan>
            <loader id="userDl">
                <query>
                    <![CDATA[select e from User e
                        where e.organization =:organization]]>
                </query>
            </loader>
        </collection>
        <collection id="projectDc"
                    class="eu.occtet.bocfrontend.entity.Project">
            <fetchPlan extends="_base">
            </fetchPlan>
            <loader id="projectDl">
                <query>
                    <![CDATA[select e from Project e
                        where e.organization =:organization]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="organizationDc" width="100%" rowSpacing="true">
            <h3 text="msg://eu.occtet.bocfrontend.view.project/OrganizationDetails" colspan="2" classNames="occtet-dialog-title"/>
            <vbox id="projectDetailContainer" colspan="2" margin="false" padding="false">
                <vbox colspan="2" margin="false" padding="false">
                    <textField id="projectNameField" property="organizationName" required="true"
                               width="50%" label="msg://organizationName" requiredMessage="msg://io.jmix.flowui.entity.filter/AbstractSingleFilterCondition.required" colspan="2"/>
                    <textField id="organizationContactField" property="organizationEmail"
                               label="msg://organizationEmail" width="50%"/>

                </vbox>
            </vbox>

            <vbox>
                <h3 text="msg://eu.occtet.bocfrontend.view.project/projectListView.title"/>
                <dataGrid id="projectDataGrid"
                          width="100%"
                          dataContainer="projectDc"
                          columnReorderingAllowed="true"
                          classNames="occtet-grid">
                    <columns resizable="true" >
                        <column property="projectName" header="msg://eu.occtet.bocfrontend.entity/Project.projectName"/>
                        <column property="version" header="msg://eu.occtet.bocfrontend.entity/Project.version"/>
                    </columns>
                </dataGrid>
                <hbox>
                    <button id="addProjectButton" text="msg://eu.occtet.bocfrontend.view.inventoryitem/button.dropdown.add" themeNames="primary"/>
                    <button id="removeProjectButton" icon="TRASH" themeNames="error"/>
                </hbox>
            </vbox>

            <vbox>
                <h3 text="msg://eu.occtet.bocfrontend.view/OrganizationMember"/>
                <dataGrid id="userDataGrid"
                          width="100%"
                          dataContainer="userDc"
                          columnReorderingAllowed="true"
                          classNames="occtet-grid">
                    <columns resizable="true" >
                        <column property="lastName" header="msg://eu.occtet.bocfrontend.entity/User.lastName"/>
                        <column property="firstName" header="msg://eu.occtet.bocfrontend.entity/User.firstName"/>
                    </columns>
                </dataGrid>
                <hbox>
                    <button id="addMemberButton" text="msg://eu.occtet.bocfrontend.view.inventoryitem/button.dropdown.add" themeNames="primary"/>
                    <button id="removeMemberButton" icon="TRASH" themeNames="error"/>
                </hbox>
            </vbox>

        </formLayout>
        <hbox id="detailActions" justifyContent="CENTER" alignItems="END" alignSelf="CENTER" height="100%" width="100%">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
