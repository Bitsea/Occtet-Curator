<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://eu.occtet.bocfrontend.view.softwareComponent/softwareComponentListView.title">
<data>
    <collection id="softwareComponentDc"
                class="eu.occtet.bocfrontend.entity.SoftwareComponent">
        <fetchPlan extends="_base"/>
        <loader id="softwareComponentDl">
            <query>
                <![CDATA[select e from SoftwareComponent e]]>
            </query>
        </loader>
    </collection>
</data>
<layout>
    <vbox width="100%" height="100%">
        <hbox width="100%">
            <textField id="searchField" placeholder="Name..."/>
            <button id="searchButton" text="Search"/>
        </hbox>
        <dataGrid id="softwareComponentDataGrid"
                  width="100%"
                  height="30em"
                  dataContainer="softwareComponentDc"
                  columnReorderingAllowed="true"
                  classNames="occtet-grid"
                  selectionMode="MULTI">
            <columns resizable="true">
                <column property="name" header="msg://eu.occtet.bocfrontend.view.softwareComponent/softwareComponent.name"/>
                <column property="version" header="msg://eu.occtet.bocfrontend.entity/SoftwareComponent.version"/>
                <column property="purl" header="msg://eu.occtet.bocfrontend.entity/SoftwareComponent.purl"/>
            </columns>
        </dataGrid>
        <hbox alignItems="CENTER" alignSelf="CENTER" justifySelf="CENTER" justifyContent="CENTER" width="100%">
            <button id="addComponentButton" text="Add" themeNames="primary"/>
            <button id="cancelButton" text="Cancel"/>
        </hbox>
    </vbox>
</layout>
</view>