<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://eu.occtet.bocfrontend.view.ortIssue/title"
        focusComponent="form">
    <data>
        <instance id="ortIssueDc"
                  class="eu.occtet.bocfrontend.entity.OrtIssue">

            <loader id="ortIssueDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>

                <vbox alignItems="CENTER" justifyContent="START" alignSelf="START" height="100%" width="100%">
                        <vbox width="100%" id="form">
                        <hbox>
                            <textField id="projectField" property="project.projectName" dataContainer="ortIssueDc" label="msg://eu.occtet.bocfrontend.entity/InventoryItem.project"/>
                            <textField id="inventoryItem" property="inventoryItem.inventoryName" dataContainer="ortIssueDc" label="msg://eu.occtet.bocfrontend.view.audit.fragment/inventoryName" />
                        </hbox>
                            <hbox>
                                <textField id="affectedPath" property="affectedPath" dataContainer="ortIssueDc"
                                           label="msg://affectedPath"/>
                                <textField id="severity" property="severity" dataContainer="ortIssueDc"
                                           label="msg://eu.occtet.bocfrontend.entity/Vulnerability.weightedSeverity"/>
                            </hbox>
                            <hbox>

                                <textField id="worker" property="worker" dataContainer="ortIssueDc"
                                           label="msg://worker"/>
                                <textField id="identifier" property="identifier" dataContainer="ortIssueDc"
                                           label="msg://identifier"/>

                                <checkbox id="resolved" property="resolved" dataContainer="ortIssueDc"
                                          label="msg://eu.occtet.bocfrontend.view.ortViolation/resolved"
                                          alignSelf="END"/>

                            </hbox>
                            <hbox width="100%">
                                <textField id="resolution" property="resolution" dataContainer="ortIssueDc"
                                           label="msg://resolution"/>
                                <textField id="timestamp" property="timestamp" dataContainer="ortIssueDc" label="msg://eu.occtet.bocfrontend.entity/VexData.timeStamp" />

                            </hbox>
                            <hbox width="100%">
                            <textField id="message" property="message" dataContainer="ortIssueDc" label="msg://eu.occtet.bocfrontend.view.ortViolation/message"  width="100%"/>

                        </hbox>



                        </vbox>

                    <hbox id="detailActions" justifyContent="CENTER" alignItems="CENTER" alignSelf="CENTER" height="100%">
                        <button id="saveAndCloseButton" action="saveAction" alignSelf="END"/>
                        <button id="closeButton" action="closeAction" alignSelf="END"/>
                    </hbox>
                </vbox>

    </layout>
</view>
