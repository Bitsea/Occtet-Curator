<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://eu.occtet.bocfrontend.view.projectMember/projectMember">
    <data>
        <collection id="projectMembersDc"
                    class="eu.occtet.bocfrontend.entity.ProjectMember">
            <fetchPlan extends="_base">
                <property name="project" fetchPlan="_base"/>
                <property name="user" fetchPlan="_base">
                    <property name="lastName"/>
                </property>
            </fetchPlan>
            <loader id="projectMembersDl">
                <query>
                    <![CDATA[
                        select e from ProjectMember e
                    ]]>
                </query>
            </loader>
        </collection>
    </data>

    <layout>
        <dataGrid id="projectMembersDataGrid"
                  dataContainer="projectMembersDc"
                  width="100%">
            <columns>
                <column property="project.projectName" header="msg://eu.occtet.bocfrontend.entity/InventoryItem.project"/>
                <column property="user.lastName" header="msg://eu.occtet.bocfrontend.view.login/loginForm.username"/>
            </columns>
        </dataGrid>
    </layout>

</view>