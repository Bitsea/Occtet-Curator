<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://fileListView.title"
      focusComponent="filesDataGrid">
    <data>
        <collection id="filesDc"
                    class="eu.occtet.bocfrontend.entity.File">
            <fetchPlan>
                <property name="projectPath"/>
                <property name="isDirectory"/>
            </fetchPlan>
            <loader id="filesDl">
                <query>
                    <![CDATA[
                        select e from File e
                        where e.project = :project
                        and e.isDirectory = false
                        order by e.projectPath asc
                    ]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <vbox id="rootLayout" height="100%" spacing="true" expand="filesDataGrid">
            <dataGrid id="filesDataGrid"
                      width="100%"
                      minHeight="20em"
                      dataContainer="filesDc"
                      selectionMode="MULTI">
                <actions>
                </actions>
                <columns resizable="true">
                    <column property="projectPath" header="msg://eu.occtet.bocfrontend.view.audit/context.projectPath" filterable="true"/>
                </columns>
                <simplePagination/>
            </dataGrid>

            <hbox id="lookupActions" spacing="true" visible="false">
                <button id="selectButton" action="selectAction" text="msg://eu.occtet.bocfrontend.view.file/fileListView.confirmAndSave.button"/>
                <button id="discardButton" action="discardAction" test="msg://eu.occtet.bocfrontend.view.file/fileListView.discard.button"/>
            </hbox>
        </vbox>
    </layout>
</view>
