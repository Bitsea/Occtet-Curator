<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://eu.occtet.bocfrontend.view.user/UserDetailView.title">
    <data>
        <collection id="userDc"
                    class="eu.occtet.bocfrontend.entity.User">
            <fetchPlan extends="_base"/>
            <loader id="userDl">
                <query>
                    <![CDATA[select e from User e]]>
                </query>
            </loader>
        </collection>
    </data>
    <layout>
        <vbox width="100%" height="100%">
            <hbox width="100%">
                <textField id="searchField" placeholder="Name..."/>
                <button id="searchButton" text="Search"/>
            </hbox>
            <dataGrid id="userDataGrid"
                      width="100%"
                      height="30em"
                      dataContainer="userDc"
                      columnReorderingAllowed="true"
                      classNames="occtet-grid"
                      selectionMode="MULTI">
                <columns resizable="true">
                    <column property="username" header="msg://eu.occtet.bocfrontend.view.login/loginForm.username"/>
                    <column property="firstName" header="msg://eu.occtet.bocfrontend.entity/User.firstName"/>
                    <column property="lastName" header="msg://eu.occtet.bocfrontend.entity/User.lastName"/>
                </columns>
            </dataGrid>
            <hbox alignItems="CENTER" alignSelf="CENTER" justifySelf="CENTER" justifyContent="CENTER" width="100%">
                <button id="addButton" text="msg://eu.occtet.bocfrontend.view.inventoryitem/button.dropdown.add" themeNames="primary"/>
                <button id="cancelButton" text="Cancel"/>
            </hbox>
        </vbox>
    </layout>
</view>